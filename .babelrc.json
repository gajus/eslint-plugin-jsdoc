{
  "plugins": [
    "add-module-exports",
    "babel-plugin-transform-import-meta"
  ],
  "presets": [
    [
      "@babel/preset-env",
      {
        "modules": "commonjs",
        "targets": {
          "node": 20
        }
      }
    ]
  ],
  "env": {
    "test": {
      "plugins": [ "istanbul" ]
    }
  }
}
